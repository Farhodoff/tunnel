# Tunnel Server Environment Configuration

# Server Settings
TUNNEL_DOMAIN=tunnel.example.com
TUNNEL_PORT=8080
TUNNEL_HOST=0.0.0.0

# Security
TUNNEL_API_KEYS=your_api_key_1,your_api_key_2

# SSL/TLS (optional - for custom certificates)
TUNNEL_SSL_CERT=/path/to/cert.pem
TUNNEL_SSL_KEY=/path/to/key.pem

# Rate Limiting
TUNNEL_RATE_LIMIT=100
TUNNEL_RATE_WINDOW=60

# Logging
TUNNEL_LOG_LEVEL=INFO
TUNNEL_LOG_FILE=/var/log/tunnel/server.log

# Database (optional - for persistent storage)
# TUNNEL_DATABASE_URL=postgresql://user:pass@localhost/tunnel

# Redis (optional - for distributed rate limiting)
# TUNNEL_REDIS_URL=redis://localhost:6379/0
